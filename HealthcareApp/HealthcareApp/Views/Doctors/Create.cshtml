@model CareBusiness.Entities.Doctor
@{
    ViewData["Title"] = "Add Doctor";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-success text-white">
                    <h3 class="text-center font-weight-light my-2">Add New Doctor</h3>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="form-floating mb-3">
                            <input asp-for="DoctorName" class="form-control" placeholder="Name" required />
                            <label asp-for="DoctorName">Doctor Name</label>
                            <span asp-validation-for="DoctorName" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Specialty" class="form-control" placeholder="Specialty" required />
                            <label asp-for="Specialty">Specialty</label>
                            <span asp-validation-for="Specialty" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="LicenseNumber" class="form-control" placeholder="License" required />
                            <label asp-for="LicenseNumber">License Number</label>
                            <span asp-validation-for="LicenseNumber" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="MaxPatients" type="number" class="form-control" placeholder="10" required />
                            <label asp-for="MaxPatients">Max Patients Per Day</label>
                            <span asp-validation-for="MaxPatients" class="text-danger small"></span>
                        </div>

                        <div class="mt-4 mb-0">
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success py-2 rounded-pill shadow-sm">Save Doctor Profile</button>
                                <a asp-action="Index" class="btn btn-outline-secondary py-2 rounded-pill">Cancel</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
