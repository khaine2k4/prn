@model CareBusiness.Entities.Appointment
@{
    ViewData["Title"] = "Book Appointment";
    var doctor = ViewBag.Doctor as CareBusiness.Entities.Doctor;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white">
                    <h3 class="text-center font-weight-light my-2">Book Appointment</h3>
                </div>
                <div class="card-body text-center">
                    <h5 class="mb-3 text-primary">Dr. @doctor?.DoctorName</h5>
                    <p class="text-muted mb-4">Specialty: @doctor?.Specialty</p>

                    <form asp-action="Book" method="post">
                        <input type="hidden" name="doctorId" value="@doctor?.ID" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label class="form-label text-start d-block fw-bold">Select Appointment Date</label>
                            <input type="date" name="appointmentDate" class="form-control form-control-lg" required min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">Confirm Booking</button>
                            <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-secondary rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
